{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist/main",
    "types": [
      "node",
      "electron"
    ],
    "lib": [
      "ES2022",
      "DOM"
    ],
    "noEmitOnError": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload.ts",
    "src/shared/**/*.ts"
  ]
}
